{
  "name": "@injectivelabs/x402",
  "version": "0.0.1",
  "description": "x402 Payment Protocol — Injective EVM Integration",
  "keywords": ["x402", "payment", "protocol", "injective", "evm", "http-402"],
  "homepage": "https://github.com/InjectiveLabs/x402#readme",
  "bugs": {
    "url": "https://github.com/InjectiveLabs/x402/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/InjectiveLabs/x402.git",
    "directory": "packages/x402-injective"
  },
  "license": "MIT",
  "author": "InjectiveLabs <admin@injectivelabs.org>",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./networks": {
      "import": "./dist/networks/index.js",
      "types": "./dist/networks/index.d.ts"
    },
    "./facilitator": {
      "import": "./dist/facilitator/index.js",
      "types": "./dist/facilitator/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./middleware": {
      "import": "./dist/middleware/index.js",
      "types": "./dist/middleware/index.d.ts"
    },
    "./protocol": {
      "import": "./dist/protocol/index.js",
      "types": "./dist/protocol/index.d.ts"
    },
    "./eip3009": {
      "import": "./dist/eip3009.js",
      "types": "./dist/eip3009.d.ts"
    },
    "./schemas": {
      "import": "./dist/schemas.js",
      "types": "./dist/schemas.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "viem": "^2.39.3",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true }
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  }
}
